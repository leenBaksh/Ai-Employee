# AI Employee — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── GENERAL ──────────────────────────────────────────────────────────────────
# Path to your Obsidian vault
VAULT_PATH=./AI_Employee_Vault

# DRY_RUN — default is "true" (safe). Set to "false" for production.
# When true: all external actions are logged but never executed.
# When false: emails send, posts publish, banking writes apply.
DRY_RUN=false

# DEV_MODE — alias for DRY_RUN. Takes precedence if set.
# DEV_MODE=true

# ── RATE LIMITING ──────────────────────────────────────────────────────────────
# Maximum outbound actions per rolling hour. Override to tighten limits.
MAX_EMAILS_PER_HOUR=10
MAX_WHATSAPP_PER_HOUR=5
MAX_SOCIAL_POSTS_PER_HOUR=3
MAX_ODOO_WRITES_PER_HOUR=5
MAX_BANKING_WRITES_PER_HOUR=3
MAX_APPROVALS_PER_HOUR=20
MAX_CALENDAR_WRITES_PER_HOUR=5

# ── GMAIL (Silver Tier) ───────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
# Guide: https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS_PATH=./secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
# Comma-separated list of labels to watch (default: INBOX,IMPORTANT)
GMAIL_WATCH_LABELS=INBOX,IMPORTANT
# How often to poll Gmail in seconds (default: 120)
GMAIL_CHECK_INTERVAL=120

# ── SMTP EMAIL SENDING (Silver Tier — Email MCP) ──────────────────────────────
# Use an App Password, NOT your real Gmail password
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=AI Employee

# ── LINKEDIN (Silver Tier) ────────────────────────────────────────────────────
# Session storage path for Playwright persistent context
LINKEDIN_SESSION_PATH=./secrets/linkedin_session
WHATSAPP_SESSION_PATH=./secrets/whatsapp_session
# Max posts per day (handbook: max 2)
LINKEDIN_MAX_POSTS_PER_DAY=2

# ── SCHEDULING (Silver Tier) ──────────────────────────────────────────────────
# Time for daily briefing (24hr format, local time)
DAILY_BRIEFING_TIME=08:00
# Day for weekly audit (monday=0 ... sunday=6)
WEEKLY_AUDIT_DAY=6
WEEKLY_AUDIT_TIME=22:00

# ── BANKING (Silver/Gold Tier) ────────────────────────────────────────────────
# Token for direct bank API access (Open Banking / Plaid / Teller.io / custom)
# For manual ledger only: leave blank — Bank_Transactions.md is used instead
# For macOS Keychain: python secrets_manager.py set BANK_API_TOKEN your_token
BANK_API_TOKEN=


# ── ODOO ERP (Gold Tier) ──────────────────────────────────────────────────────
# Full JSON-RPC connection to your Odoo instance
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your_database
ODOO_USER=admin@company.com
ODOO_PASSWORD=your_odoo_password

# ── GOOGLE CALENDAR MCP ───────────────────────────────────────────────────────
# Reuses the same OAuth token as Gmail watcher (gmail_token.json)
GOOGLE_CALENDAR_ID=primary             # 'primary' or a specific calendar ID

# ── SLACK MCP ─────────────────────────────────────────────────────────────────
# 1. https://api.slack.com/apps → Create App → From scratch
# 2. OAuth & Permissions → Bot Token Scopes: channels:read, channels:history,
#    chat:write, reactions:write
# 3. Install App to Workspace → copy Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_WORKSPACE=your-workspace-name    # display name only

# ── SOCIAL MEDIA — Playwright MCP (Gold Tier) ─────────────────────────────────
# All posting is done via browser automation (same pattern as LinkedIn)
# Max posts per platform per day
FACEBOOK_MAX_POSTS_PER_DAY=2
INSTAGRAM_MAX_POSTS_PER_DAY=2
TWITTER_MAX_POSTS_PER_DAY=5

# ── WHATSAPP BUSINESS (Silver Tier) ──────────────────────────────────────────
# Meta WhatsApp Business Cloud API — free tier
# Setup guide: uv run whatsapp-watcher --setup
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Port for the webhook HTTP server (Meta sends events here)
WHATSAPP_WEBHOOK_PORT=8089

# ── RALPH WIGGUM LOOP (Gold Tier) ─────────────────────────────────────────────
# Claude Code Stop Hook that keeps Claude looping until a task is truly done
RALPH_MAX_ITERATIONS=10
RALPH_STATE_DIR=./AI_Employee_Vault/Ralph_State

# ── PLATINUM TIER — Cloud Agent ───────────────────────────────────────────────
# Unique identifier for this agent instance ("cloud-01" on VM, "local-01" on laptop)
CLOUD_AGENT_ID=cloud-01
# How often the Cloud Agent polls for new tasks (seconds)
CLOUD_AGENT_INTERVAL=60
# Seconds without heartbeat before an agent is considered offline
HEALTH_OFFLINE_THRESHOLD=300
HEALTH_CHECK_INTERVAL=60

# ── PLATINUM TIER — Vault Sync ────────────────────────────────────────────────
# Git branch used for vault sync between Cloud and Local agents
VAULT_SYNC_BRANCH=main
# Git remote URL for vault sync (set this on both Cloud VM and Local machine)
# VAULT_SYNC_REMOTE=git@github.com:youruser/ai-employee-vault.git
